{
  "name": "@botvalia/botvalia-code",
  "version": "999.0.0-restored",
  "private": true,
  "description": "BotValia CLI source tree reconstructed from source maps.",
  "license": "SEE LICENSE IN LICENSE.md",
  "type": "module",
  "packageManager": "bun@1.3.5",
  "bin": {
    "botvalia": "./bin/botvalia.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GaruBrothers/botvalia-code.git"
  },
  "homepage": "https://github.com/GaruBrothers/botvalia-code",
  "bugs": {
    "url": "https://github.com/GaruBrothers/botvalia-code/issues"
  },
  "engines": {
    "bun": ">=1.3.5",
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "bun run ./src/dev-entry.ts",
    "start": "bun run ./src/dev-entry.ts",
    "version": "bun run ./src/dev-entry.ts --version",
    "typecheck": "tsc --noEmit",
    "security:preflight": "bun run ./scripts/security-preflight.ts",
    "dev:auto": "powershell -ExecutionPolicy Bypass -File ./scripts/dev-auto.ps1 -Preset auto-all",
    "version:auto": "powershell -ExecutionPolicy Bypass -File ./scripts/dev-auto.ps1 -Preset auto-all -VersionOnly",
    "dev:auto:all": "powershell -ExecutionPolicy Bypass -File ./scripts/dev-auto.ps1 -Preset auto-all",
    "version:auto:all": "powershell -ExecutionPolicy Bypass -File ./scripts/dev-auto.ps1 -Preset auto-all -VersionOnly",
    "dev:auto:openrouter": "powershell -ExecutionPolicy Bypass -File ./scripts/dev-auto.ps1 -Preset auto-openrouter",
    "version:auto:openrouter": "powershell -ExecutionPolicy Bypass -File ./scripts/dev-auto.ps1 -Preset auto-openrouter -VersionOnly",
    "dev:auto:ollama": "powershell -ExecutionPolicy Bypass -File ./scripts/dev-auto.ps1 -Preset auto-ollama",
    "version:auto:ollama": "powershell -ExecutionPolicy Bypass -File ./scripts/dev-auto.ps1 -Preset auto-ollama -VersionOnly",
    "dev:free": "powershell -ExecutionPolicy Bypass -File ./scripts/dev-free.ps1",
    "version:free": "powershell -ExecutionPolicy Bypass -File ./scripts/dev-free.ps1 -VersionOnly",
    "dev:openrouter": "powershell -ExecutionPolicy Bypass -File ./scripts/dev-openrouter.ps1",
    "version:openrouter": "powershell -ExecutionPolicy Bypass -File ./scripts/dev-openrouter.ps1 -VersionOnly",
    "models:openrouter:free": "powershell -ExecutionPolicy Bypass -File ./scripts/list-openrouter-free-models.ps1",
    "model:openrouter:set": "powershell -ExecutionPolicy Bypass -File ./scripts/set-openrouter-model.ps1",
    "model:openrouter:clear": "powershell -ExecutionPolicy Bypass -File ./scripts/clear-openrouter-model.ps1",
    "smoke:router:fallback": "powershell -ExecutionPolicy Bypass -File ./scripts/smoke-free-router-fallback.ps1",
    "smoke:router:fallback:json": "powershell -ExecutionPolicy Bypass -File ./scripts/smoke-free-router-fallback.ps1 -Json"
  },
  "dependencies": {
    "@alcalzone/ansi-tokenize": "0.3.0",
